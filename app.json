{
  "expo": {
    "name": "Habit Quest",
    "slug": "habit-quest-mobile",
    "scheme": "habitquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "ios": {
      "bundleIdentifier": "com.iivan.habitquest",
      "supportsTablet": false
    },
    "android": {
      "package": "com.iivan.habitquest",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94d9a2ce-9760-43a0-a816-d5c88f121688"
      }
    }
  }
}
